# Copy to .env for local development. Never commit the real .env.
DATABASE_URL="postgresql://library:library@localhost:5432/university_library?schema=public"
PORT=3000
NODE_ENV=development

# JWT relying-party config (see security/ and stack-decision.md §1).
# Dev: PublicKeyProvider reads the mock IdP's static key below.
# Prod: PublicKeyProvider fetches the university IdP's JWKS endpoint instead —
# only this binding changes, nothing downstream.
JWT_PUBLIC_KEY_SOURCE=static
MOCK_IDP_SIGNING_SECRET=dev-only-mock-idp-secret-change-me
JWKS_URI=https://idp.example.edu/.well-known/jwks.json
